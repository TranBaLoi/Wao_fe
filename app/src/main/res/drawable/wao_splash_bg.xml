<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/wao_background_dark"/>
        </shape>
    </item>
    <item android:top="-100dp" android:left="-100dp" android:width="400dp" android:height="400dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="200dp"
                android:startColor="#3313ec5b"
                android:endColor="#0013ec5b"
                android:centerX="50%"
                android:centerY="50%"/>
        </shape>
    </item>
     <item android:bottom="-100dp" android:right="-100dp" android:width="400dp" android:height="400dp" android:gravity="bottom|end">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="200dp"
                android:startColor="#1A13ec5b"
                android:endColor="#0013ec5b"
                android:centerX="50%"
                android:centerY="50%"/>
        </shape>
    </item>
</layer-list>
