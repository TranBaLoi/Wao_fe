<?xml version="1.0" encoding="utf-8"?>
<!-- nam them -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/wao_slate_100"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/wao_slate_200"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_point_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="24/03/2026"
            android:textColor="@color/wao_slate_900"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_point_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            tools:text="Calories 0 kcal"
            android:textColor="@color/wao_primary"
            android:textAppearance="?attr/textAppearanceSubtitle2"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_metric_one"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            tools:text="Metric one"
            android:textColor="@color/wao_slate_600"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tv_metric_two"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            tools:text="Metric two"
            android:textColor="@color/wao_slate_600"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tv_metric_three"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            tools:text="Metric three"
            android:textColor="@color/wao_slate_600"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tv_metric_four"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            tools:text="Metric four"
            android:textColor="@color/wao_slate_600"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textSize="17sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
