<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_light_bg"
    tools:context="com.example.wao_fe.MealPlanActivity">

    <!-- Phần Nội dung chính (Đặt trong ConstraintLayout) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"> <!-- Chừa chỗ cho thanh Bottom Bar -->

        <!-- Header -->
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnBackHeader"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                app:tint="@color/wao_slate_900"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thứ 2, 26 tháng 3"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thực đơn hôm nay"
                    android:textColor="@color/wao_slate_900"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/layoutHeader"
            app:layout_constraintBottom_toTopOf="@id/bottomBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Shimmer Layout -->
                <com.facebook.shimmer.ShimmerFrameLayout
                    android:id="@+id/shimmerViewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:shimmer_auto_start="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <View
                            android:layout_width="100dp"
                            android:layout_height="20dp"
                            android:background="#E2E8F0"
                            android:layout_marginBottom="12dp"/>

                        <include layout="@layout/item_meal_food_shimmer" />
                        <include layout="@layout/item_meal_food_shimmer" />

                        <View
                            android:layout_width="100dp"
                            android:layout_height="20dp"
                            android:background="#E2E8F0"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="12dp"/>

                        <include layout="@layout/item_meal_food_shimmer" />
                        <include layout="@layout/item_meal_food_shimmer" />
                    </LinearLayout>
                </com.facebook.shimmer.ShimmerFrameLayout>

                <!-- Actual Content -->
                <LinearLayout
                    android:id="@+id/contentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Breakfast -->
                    <TextView
                        android:id="@+id/tvBreakfastLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BỮA SÁNG"
                        android:textColor="@color/wao_slate_600"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/listBreakfast"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"/>

                    <!-- Lunch -->
                    <TextView
                        android:id="@+id/tvLunchLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BỮA TRƯA"
                        android:textColor="@color/wao_slate_600"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/listLunch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"/>

                    <!-- Dinner -->
                    <TextView
                        android:id="@+id/tvDinnerLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BỮA TỐI"
                        android:textColor="@color/wao_slate_600"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/listDinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvSavedPlansTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Meal Plan đã tạo"
                    android:textColor="@color/wao_slate_800"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressSavedPlans"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/listSavedPlans"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tvSavedPlansEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Bạn chưa tạo Meal Plan nào."
                    android:textColor="@color/wao_slate_500"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- Empty State -->
                <LinearLayout
                    android:id="@+id/emptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="80dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_bulb"
                        app:tint="@color/wao_slate_300"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa có thực đơn nào"
                        android:textColor="@color/wao_slate_500"
                        android:textSize="16sp"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhấn nút nổi bên dưới để nhờ AI lên menu"
                        android:textColor="@color/wao_slate_400"
                        android:textSize="14sp"
                        android:textAlignment="center"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Nút Gợi ý lại (Được đưa lên TRÊN bottomBar) -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fabGenerateAI"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Nhờ AI Gợi Ý"
            android:textColor="@color/white"
            app:iconTint="@color/white"
            android:backgroundTint="@color/wao_primary"
            app:layout_constraintBottom_toTopOf="@id/bottomBar"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="16dp"
            android:layout_marginEnd="20dp"
            android:elevation="6dp"/>

        <!-- Bottom Bar (Apply button) -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card_white"
            android:elevation="8dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/btnApply"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/green_dark"
                android:text="✅ Áp dụng Thực đơn này"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"/>
        </LinearLayout>

        <!-- Lottie Overlay -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lottieOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CCFFFFFF"
            android:visibility="gone"
            android:translationZ="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottieAnimation"
                android:layout_width="200dp"
                android:layout_height="200dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:lottie_autoPlay="false"
                app:lottie_loop="false"
                app:lottie_rawRes="@raw/anim_success" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- THANH BOTTOM BAR CHÍNH (Giống hệt MainActivity) -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:backgroundTint="@android:color/white"
        app:fabCradleMargin="10dp"
        app:fabCradleRoundedCornerRadius="20dp"
        app:fabCradleVerticalOffset="10dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigationView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@android:color/transparent"
            app:elevation="0dp"
            app:itemIconTint="@color/green_dark"
            app:itemTextColor="@color/green_dark"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />
    </com.google.android.material.bottomappbar.BottomAppBar>

    <!-- Nút cộng (+) ở giữa (Giống hệt MainActivity) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddFood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Thêm món ăn mới"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/green_primary"
        app:tint="@android:color/white"
        app:layout_anchor="@id/bottomAppBar"
        app:layout_anchorGravity="center" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>