<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_light_bg"
    android:padding="16dp">

    <!-- Header -->
    <ImageView
        android:id="@+id/btnBackHeader"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/green_dark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wao"
        android:textColor="@color/green_dark"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBackHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnBackHeader" />

    <!-- Progress Info -->
    <TextView
        android:id="@+id/tvStep"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="BƯỚC 2/4"
        android:textColor="@color/green_dark"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnBackHeader" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="50% Hoàn tất"
        android:textColor="@color/text_secondary"
        app:layout_constraintBottom_toBottomOf="@+id/tvStep"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvStep" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginTop="8dp"
        android:max="4"
        android:progress="2"
        android:progressDrawable="@drawable/custom_progress_drawable"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvStep" />

    <!-- Title and Description -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Chỉ số cơ thể"
        android:textColor="@color/green_dark"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/progressBar" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Chúng tôi cần các chỉ số này để tính toán lượng calo và dinh dưỡng tối ưu cho bạn."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/bottomButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Height Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CHIỀU CAO"
                                android:textAllCaps="true"
                                android:textColor="@color/green_dark"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="bottom">
                                <TextView
                                    android:id="@+id/tvHeightVal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="172"
                                    android:textColor="@color/wao_slate_900"
                                    android:textSize="32sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" cm"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="16sp"
                                    android:layout_marginBottom="6dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_logo_circle"
                            android:backgroundTint="@color/green_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_ruler"
                            app:tint="@color/green_dark" />
                    </LinearLayout>

                    <!-- Visualization of ruler (simplified) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center|bottom">
                         <!-- Just some lines to mimic the look -->
                          <View android:layout_width="1dp" android:layout_height="10dp" android:background="#E0E0E0" android:layout_marginHorizontal="2dp"/>
                          <View android:layout_width="1dp" android:layout_height="20dp" android:background="#E0E0E0" android:layout_marginHorizontal="2dp"/>
                          <View android:layout_width="1dp" android:layout_height="10dp" android:background="#E0E0E0" android:layout_marginHorizontal="2dp"/>
                          <View android:layout_width="1dp" android:layout_height="15dp" android:background="#E0E0E0" android:layout_marginHorizontal="2dp"/>
                          <View android:layout_width="2dp" android:layout_height="40dp" android:background="@color/green_dark" android:layout_marginHorizontal="4dp"/>
                           <View android:layout_width="1dp" android:layout_height="15dp" android:background="#E0E0E0" android:layout_marginHorizontal="2dp"/>
                          <View android:layout_width="1dp" android:layout_height="10dp" android:background="#E0E0E0" android:layout_marginHorizontal="2dp"/>
                          <View android:layout_width="1dp" android:layout_height="20dp" android:background="#E0E0E0" android:layout_marginHorizontal="2dp"/>
                          <View android:layout_width="1dp" android:layout_height="10dp" android:background="#E0E0E0" android:layout_marginHorizontal="2dp"/>
                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderHeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="100.0"
                        android:valueTo="220.0"
                        android:value="170.0"
                        app:thumbColor="@color/green_medium"
                        app:trackColorActive="@color/green_medium"
                        app:trackColorInactive="@color/green_light_bg" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Weight Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CÂN NẶNG"
                                android:textAllCaps="true"
                                android:textColor="@color/green_dark"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="bottom">
                                <TextView
                                    android:id="@+id/tvWeightVal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="68.5"
                                    android:textColor="@color/wao_slate_900"
                                    android:textSize="32sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" kg"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="16sp"
                                    android:layout_marginBottom="6dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_logo_circle"
                            android:backgroundTint="@color/green_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_scale"
                            app:tint="@color/green_dark" />
                    </LinearLayout>

                    <!-- Weight Control -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_gender_unselected"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp">

                         <ImageView
                            android:id="@+id/btnDecreaseWeight"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                             android:src="@drawable/ic_minus"
                             android:padding="8dp"
                             android:background="@drawable/circle_primary_alpha"
                             app:tint="@color/green_dark"
                             android:clickable="true"
                             android:focusable="true"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Điều chỉnh"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary" />

                        <ImageView
                            android:id="@+id/btnIncreaseWeight"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_add"
                            android:padding="8dp"
                            android:background="@drawable/circle_primary_alpha"
                            app:tint="@color/green_dark"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <!-- BMI Result -->
                    <TextView
                        android:id="@+id/tvBMIResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="BMI: 23.1 (Bình thường)"
                        android:gravity="center"
                        android:textColor="@color/green_dark"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:background="#E8F5E9"
                        android:padding="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:weightSum="1"
        android:background="#00FFFFFF"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quay lại"
            android:textColor="@color/green_dark"
            android:textStyle="bold"
            android:textSize="16sp"
            android:drawableStart="@drawable/ic_arrow_back"
            android:drawablePadding="8dp"
            app:drawableTint="@color/green_dark"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginEnd="16dp"/>

        <!-- Add a spacer to push the button to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiếp tục"
            android:backgroundTint="@color/green_dark"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:paddingHorizontal="32dp"
            android:paddingVertical="12dp"
            app:cornerRadius="24dp"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="end"
            app:iconTint="@android:color/white"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
