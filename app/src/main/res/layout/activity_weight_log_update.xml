<?xml version="1.0" encoding="utf-8"?>
<!-- namthem -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_back_weight_log"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="Quay lại"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/wao_slate_900" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Cập nhật cân nặng"
                android:textColor="@color/wao_slate_900"
                android:textSize="30sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Ngày ghi log"
            android:textColor="@color/wao_slate_600"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn_choose_weight_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Chọn ngày"
            android:textAllCaps="false"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Cân nặng mới (kg)"
            android:textColor="@color/wao_slate_600"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/et_new_weight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/edit_text"
            android:hint="Ví dụ: 68.5"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Ghi chú (không bắt buộc)"
            android:textColor="@color/wao_slate_600"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/et_weight_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/edit_text"
            android:hint="Nhập ghi chú nếu cần"
            android:minLines="3"
            android:gravity="top|start"
            android:padding="12dp"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_weight_log_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/wao_slate_600"
            android:textSize="18sp" />

        <ProgressBar
            android:id="@+id/progress_weight_log"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_save_weight_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Lưu cân nặng"
            android:textAllCaps="false"
            android:textSize="20sp" />
    </LinearLayout>
</ScrollView>
