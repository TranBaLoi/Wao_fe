<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:id="@+id/ivFoodImage"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:background="@drawable/bg_logo_square"
            android:padding="18dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_wao_leaf" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFoodName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:text="Tên món"
                android:textColor="#1B231F"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 kcal"
                    android:textColor="#9C5F00"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="/"
                    android:textColor="#66736B"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvServing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="100g"
                    android:textColor="#66736B"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Mô tả"
                android:textColor="#4A544E"
                android:textSize="15sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnAddFood"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:background="@drawable/fs_bg_add_orange"
            android:contentDescription="Thêm món"
            android:src="@android:drawable/ic_input_add"
            android:tint="#3B2A00" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
