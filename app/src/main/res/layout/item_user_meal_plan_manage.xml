<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvMealPlanName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thực Đơn"
        android:textColor="@color/wao_slate_900"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMealPlanMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Loại"
        android:textColor="@color/wao_slate_600"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvFoodsCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="0 Món Ăn"
        android:textColor="@color/wao_slate_500"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnViewDetail"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Chi Tiết"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnAdjust"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Điều Chỉnh"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/error_red"
            android:text="Xóa"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnApplyToDiary"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/green_dark"
        android:text="Áp Dụng Vào Thực Đơn"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="12sp" />

</LinearLayout>




