<?xml version="1.0" encoding="utf-8"?>
<!-- nam them -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wao_background_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_dashboard_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Dang tai du lieu..."
            android:textColor="@color/wao_slate_500"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/progress_dashboard"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginBottom="16dp"
            android:indeterminate="true"
            android:progressTint="@color/wao_primary" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chon cach xem"
                    android:textColor="@color/wao_slate_900"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_period_day"
                        style="@style/Widget.Wao.Button"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Theo ngay"
                        android:textSize="13sp"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_period_week"
                        style="@style/Widget.Wao.Button"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Theo tuan"
                        android:textSize="13sp"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_period_month"
                        style="@style/Widget.Wao.Button"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Theo thang"
                        android:textSize="13sp"
                        android:textAllCaps="false" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_choose_date"
                    style="@style/Widget.Wao.Button"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:text="Chon ngay"
                    android:textSize="13sp"
                    android:textAllCaps="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_chart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tv_selected_range_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thong ke theo tuan"
                    android:textColor="@color/wao_slate_900"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_selected_range_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tu 01/01/2026 den 07/01/2026"
                    android:textColor="@color/wao_slate_500"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/spinner_metric"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="14dp"
                    android:background="@android:drawable/editbox_background"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:spinnerMode="dropdown" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Bieu do xu huong"
                    android:textColor="@color/wao_slate_900"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_chart_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Cham vao diem de xem chi tiet ngay"
                    android:textColor="@color/wao_slate_500"
                    android:textSize="13sp" />

                <com.example.wao_fe.namstats.views.NamTrendChartView
                    android:id="@+id/chart_trend"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="14dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/container_detail_items"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
