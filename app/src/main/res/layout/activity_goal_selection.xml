<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_light_bg"
    android:padding="16dp">

    <!-- Header -->
    <ImageView
        android:id="@+id/btnBackHeader"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/green_dark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wao"
        android:textColor="@color/green_dark"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBackHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnBackHeader" />

    <!-- Progress Info -->
    <TextView
        android:id="@+id/tvStep"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="BƯỚC 3/4"
        android:textColor="@color/green_dark"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnBackHeader" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="75% Hoàn tất"
        android:textColor="@color/text_secondary"
        app:layout_constraintBottom_toBottomOf="@+id/tvStep"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvStep" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginTop="8dp"
        android:max="4"
        android:progress="3"
        android:progressDrawable="@drawable/custom_progress_drawable"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvStep" />

    <!-- Title and Description -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Mục tiêu của bạn"
        android:textColor="@color/green_dark"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/progressBar" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Để chúng tôi thiết lập lộ trình tập luyện và dinh dưỡng cá nhân hóa nhất cho bạn."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle" />

    <!-- Goal Selection -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/cardInfo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card 1: Weight Loss -->
            <LinearLayout
                android:id="@+id/cardLoseWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_goal_unselected"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iconLoseWeight"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_goal_weight_loss"
                    android:padding="12dp"
                    android:background="@drawable/bg_logo_circle"
                    android:backgroundTint="@color/green_accent"
                    app:tint="@color/wao_background_dark"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giảm cân"
                        android:textStyle="bold"
                        android:textColor="@color/green_dark"
                        android:textSize="18sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đốt cháy mỡ thừa và đạt được mức cân nặng lý tưởng của bạn."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/radioLoseWeight"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_circle_outline"
                    android:padding="2dp"/>
            </LinearLayout>

            <!-- Card 2: Maintain -->
            <LinearLayout
                android:id="@+id/cardMaintain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_goal_selected"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                 <ImageView
                     android:id="@+id/iconMaintain"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_goal_maintain"
                    android:padding="12dp"
                    android:background="@drawable/bg_logo_circle"
                    app:tint="@color/wao_background_dark"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giữ dáng"
                        android:textStyle="bold"
                        android:textColor="@color/green_dark"
                        android:textSize="18sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Duy trì lối sống năng động và cải thiện sức bền mỗi ngày."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>
                </LinearLayout>

                 <ImageView
                    android:id="@+id/radioMaintain"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_circle_filled"
                    android:padding="2dp"/>
            </LinearLayout>

            <!-- Card 3: Gain Muscle -->
            <LinearLayout
                android:id="@+id/cardGainMuscle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_goal_unselected"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                 <ImageView
                     android:id="@+id/iconGainMuscle"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_goal_muscle"
                    android:padding="12dp"
                    android:background="@drawable/bg_logo_circle"
                     android:backgroundTint="@color/green_accent"
                    app:tint="@color/wao_background_dark"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tăng cơ"
                        android:textStyle="bold"
                        android:textColor="@color/green_dark"
                        android:textSize="18sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tập trung vào các bài tập sức mạnh để xây dựng cơ bắp săn chắc."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>
                </LinearLayout>

                 <ImageView
                    android:id="@+id/radioGainMuscle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_circle_outline"
                    android:padding="2dp"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cân nặng mong muốn"
                        android:textColor="@color/green_dark"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvCurrentWeightNote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Cân nặng hiện tại: 68.5 kg"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_gender_unselected"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/btnDecreaseDesiredWeight"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circle_primary_alpha"
                            android:padding="12dp"
                            android:rotation="270"
                            android:src="@drawable/ic_wao_leaf"
                            app:tint="@color/green_dark" />

                        <TextView
                            android:id="@+id/tvDesiredWeightVal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="68.5 kg"
                            android:textColor="@color/wao_slate_900"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/btnIncreaseDesiredWeight"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circle_primary_alpha"
                            android:padding="12dp"
                            android:rotation="90"
                            android:src="@drawable/ic_wao_leaf"
                            app:tint="@color/green_dark" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvGoalValidationHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text=""
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Info Card -->
    <LinearLayout
        android:id="@+id/cardInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_logo_circle"
        android:backgroundTint="@color/green_light_bg"
         android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@+id/btnContinue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_info_circle"
            app:tint="@color/green_dark"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&quot;Mọi mục tiêu lớn đều bắt đầu từ một quyết định nhỏ hôm nay.&quot;"
            android:textColor="@color/wao_slate_900"
            android:textStyle="italic"
            android:textSize="13sp"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

    <!-- Bottom Buttons -->
    <TextView
        android:id="@+id/tvBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quay lại"
        android:textColor="@color/green_dark"
        android:textStyle="bold"
        android:textSize="16sp"
        android:drawableStart="@drawable/ic_arrow_back"
        android:drawablePadding="8dp"
        app:drawableTint="@color/green_dark"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnContinue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tiếp tục"
        android:backgroundTint="@color/green_dark"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:paddingHorizontal="32dp"
        android:paddingVertical="12dp"
        app:cornerRadius="24dp"
        app:icon="@drawable/ic_arrow_forward"
        app:iconGravity="end"
        app:iconTint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
